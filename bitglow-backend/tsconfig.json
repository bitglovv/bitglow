{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "rootDir": ".",
        "outDir": "dist"
    },
    "include": ["src/**/*.ts", "scripts/**/*.ts"],
    "exclude": ["dist", "src/**/*.js"]
}
